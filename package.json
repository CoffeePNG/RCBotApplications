{
  "name": "rcbotapplications",
  "version": "1.0.0",
  "description": "Config-driven Discord ticket bot (staff applications, bug reports, appeals, help requests) with claim/close/archive and a moderation suite, for Republicraft.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "deploy-commands": "ts-node src/deploy-commands.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
